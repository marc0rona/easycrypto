{
  "manifest_version": 3,
  "name": "EZ-CRYPT0",
  "description": "Detect and securely save crypto addresses from web pages.",
  "version": "1.0.1",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://api.ez-crypt0.example.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "EZ-CRYPT0"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
